		summarizeBy: none
		sourceColumn: visit_source_concept_id

		annotation SummarizationSetBy = Automatic

	/// Standard concept ID representing where the patient was admitted from, such as home or a long-term care facility.
	column admitting_source_concept_id
		dataType: int64
		formatString: 0
		lineageTag: 94a7ec44-e4fa-4282-856d-3566901e5592
		summarizeBy: none
		sourceColumn: admitting_source_concept_id

