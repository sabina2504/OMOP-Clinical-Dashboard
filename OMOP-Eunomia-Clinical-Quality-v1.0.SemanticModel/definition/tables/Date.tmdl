		sourceColumn: [YearMonth]
		sortByColumn: MonthSort

	partition Date = calculated
		mode: import
		source =
				VAR _StartDate = DATE(1908,1,1)
				VAR _EndDate = DATE(2019,12,31)
				VAR _Dates = CALENDAR(_StartDate, _EndDate)
				RETURN
				ADDCOLUMNS(
				    _Dates,
				    "DateKey",         FORMAT([Date], "YYYYMMDD") + 0,
				    "Year",            YEAR([Date]),
				    "Quarter",         QUARTER([Date]),
				    "QuarterLabel",    "Q" & QUARTER([Date]) & " " & YEAR([Date]),
				    "Month",           MONTH([Date]),
				    "MonthName",       FORMAT([Date], "MMMM"),
				    "MonthShort",      FORMAT([Date], "MMM"),
				    "MonthYear",       FORMAT([Date], "MMM YYYY"),
				    "MonthSort",       YEAR([Date]) * 100 + MONTH([Date]),
				    "WeekNumber",      WEEKNUM([Date], 2),
				    "DayOfWeek",       WEEKDAY([Date], 2),
				    "DayOfWeekName",   FORMAT([Date], "dddd"),
				    "DayOfWeekShort",  FORMAT([Date], "ddd"),
				    "DayOfMonth",      DAY([Date]),
				    "DayOfYear",       DATEDIFF(DATE(YEAR([Date]),1,1), [Date], DAY) + 1,
				    "IsWeekend",       IF(WEEKDAY([Date], 2) >= 6, TRUE, FALSE),
				    "YearMonth",       YEAR([Date]) & "-" & FORMAT(MONTH([Date]), "00")
				)

